# NEPSE Quant Pro - Environment Variables
# Copy this to .env and adjust for your environment.

# Path to SQLite database file (absolute or relative to project root)
NEPSE_DB_FILE=nepse_market_data.db

# Active config profile: nepse_research | nepse_prod | nepse_portfolio_alpha
# Leave unset for default config.
# NEPSE_PROFILE=nepse_prod

# Ensemble random seeds (comma-separated ints)
# NEPSE_ENSEMBLE_SEEDS=0,101,202

# Walk-forward validation model seed
# NEPSE_WFV_SEED=42

# Probability edge bootstrap seed
# NEPSE_EDGE_SEED=42

# Deployment gate output path
# DEPLOYMENT_GATE_PATH=artifacts/deployment_gate.json

# Intraday market data routing
# Nepalstock via NepseUnofficialApi is primary; MeroLagani stays as fallback.
NEPSE_INTRADAY_CACHE_SECS=15
NEPSE_INTRADAY_DB_FALLBACK_MAX_AGE_SECS=900

# Nepalstock TLS validation. Keep false unless Nepalstock's certificate chain
# is fixed in your environment and you have verified it works.
NEPALSTOCK_TLS_VERIFY=false

# Owner Telegram bot (private control surface)
# NEPSE_TELEGRAM_BOT_TOKEN=123456:owner-token
# NEPSE_TELEGRAM_CHAT_ID=123456789

# Viewer Telegram bot (read-only public surface)
# Separate bot token for stronger security isolation.
# NEPSE_VIEWER_TELEGRAM_BOT_TOKEN=123456:viewer-token
# Comma-separated private chat IDs allowed to query the viewer bot.
# NEPSE_VIEWER_TELEGRAM_ALLOWED_CHAT_IDS=111111111,222222222
# Optional broadcast chat/channel for daily public posts and trade updates.
# If unset, viewer posts go to the allowed chat IDs.
# NEPSE_VIEWER_TELEGRAM_POST_CHAT_ID=-1001234567890

# Viewer privacy / posting toggles
# NEPSE_VIEWER_DAILY_POSTS=true
# NEPSE_VIEWER_SHOW_TRADES=true
# NEPSE_VIEWER_SHOW_BENCHMARK=true
# NEPSE_VIEWER_SHOW_HOLDINGS=true

# NepalOSINT event-aware ranking layer
# Use the API root, not a single endpoint. Production convention:
# NEPALOSINT_API_BASE_URL=https://nepalosint.com/api/v1
# Optional: direct bearer token if you already have one.
# NEPALOSINT_API_KEY=
# Optional: login with an analyst/dev account instead of guest.
# NEPALOSINT_API_EMAIL=
# NEPALOSINT_API_PASSWORD=
# If no token or credentials are set, the bot can try guest auth.
# NEPALOSINT_API_USE_GUEST_LOGIN=true
# NEPSE_EVENT_LAYER_ENABLED=true
# NEPSE_EVENT_LOOKBACK_HOURS=12
# NEPSE_EVENT_MODEL=gpt-4.1-mini
# NEPSE_EVENT_MIN_CONFIDENCE=0.45
# OPENAI_API_KEY=

# Local TMS browser automation
# Enable live execution modes:
#   paper = local paper trading only
#   live  = broker execution with local mirrored state
#   dual  = broker execution plus mirrored local sleeve/accounting
#   shadow_live = approval and audit flow without broker submission
# NEPSE_LIVE_EXECUTION_ENABLED=false
# NEPSE_LIVE_EXECUTION_MODE=paper
# NEPSE_TMS_BASE_URL=https://tms19.nepsetms.com.np/tms/client/dashboard
# NEPSE_TMS_BROWSER=chrome
# NEPSE_TMS_PROFILE_DIR=.tms_profile
# NEPSE_TMS_HEADLESS=false
# Prefer environment variables or an external secret file over workspace plaintext files.
# NEPSE_TMS_SECRET_FILE=~/.config/nepse/tms.env
# NEPSE_TMS_USERNAME=
# NEPSE_TMS_PASSWORD=
# NEPSE_LIVE_OWNER_CONFIRM_REQUIRED=true
# NEPSE_LIVE_STRATEGY_AUTOMATION_ENABLED=false
# NEPSE_LIVE_AUTO_EXITS_ENABLED=true
# NEPSE_LIVE_MAX_ORDER_NOTIONAL=250000
# NEPSE_LIVE_MAX_DAILY_ORDERS=20
# NEPSE_LIVE_SYMBOL_COOLDOWN_SECS=120
# NEPSE_LIVE_MAX_PRICE_DEVIATION_PCT=2.5
# NEPSE_LIVE_SCREENSHOT_DIR=artifacts/tms_receipts
# NEPSE_LIVE_AUDIT_DB_FILE=nepse_live_audit.db
# NEPSE_LIVE_FAILSAFE_FREEZE_ON_UNCERTAIN_SUBMIT=true
# Optional selector overrides for TMS UI changes:
# NEPSE_TMS_SELECTORS_FILE=selectors/tms19.json
# NEPSE_TMS_SELECTORS_JSON={"order_buy_button":["button:has-text('Buy')"]}
